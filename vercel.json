{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "config/**" }
    },
    {
      "src": "api/setup.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/webhook", "dest": "/api/index" },
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ]
}
